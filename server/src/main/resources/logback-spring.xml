<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n"/>
    <property name="LOG_DIR" value="${LOG_PATH:-${java.io.tmpdir}/floating-ball-server/logs}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/floating-ball-server.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/floating-ball-server.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="com.regionalai.floatingball.server" level="${LOG_LEVEL:-INFO}"/>

    <logger name="com.regionalai.floatingball.server.modules.device.service.DeviceService" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.ai" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.audit" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.config" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.auth" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.knowledge" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.release" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.feedback" level="INFO"/>
    <logger name="com.regionalai.floatingball.server.modules.datapackage" level="INFO"/>

    <logger name="org.springframework.web.servlet" level="WARN"/>
    <logger name="org.springframework.web.socket" level="WARN"/>
    <logger name="com.baomidou.mybatisplus" level="WARN"/>
    <logger name="org.apache.ibatis" level="WARN"/>

    <springProfile name="development">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.regionalai.floatingball.server" level="DEBUG"/>
    </springProfile>

    <springProfile name="xiaoshan">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.regionalai.floatingball.server" level="DEBUG"/>
    </springProfile>

    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.regionalai.floatingball.server" level="INFO"/>
    </springProfile>

    <springProfile name="gaussdb">
        <root level="${FB_LOG_ROOT_LEVEL:-INFO}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.regionalai.floatingball.server" level="${FB_APP_LOG_LEVEL:-INFO}"/>
    </springProfile>

    <springProfile name="product">
        <root level="WARN">
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.regionalai.floatingball.server" level="WARN"/>
    </springProfile>

</configuration>
